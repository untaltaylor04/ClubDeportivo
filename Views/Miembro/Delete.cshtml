@model ClubDeportivo.Models.Miembro

@{
    ViewData["Title"] = "Suspender Miembro";
}

<h2 class="text-danger mb-3">Suspender Miembro</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-body">
                <h5 class="text-danger mb-3">
                    ¿Estás seguro de suspender a este miembro?
                </h5>

                <dl class="row mb-0">
                    <dt class="col-sm-4">Nombre</dt>
                    <dd class="col-sm-8">@Model.nombre</dd>

                    <dt class="col-sm-4">Apellido</dt>
                    <dd class="col-sm-8">@Model.apellido</dd>

                    <dt class="col-sm-4">Fecha Nacimiento</dt>
                    <dd class="col-sm-8">
                        @Model.fechaNacimiento.ToString("dd/MM/yyyy")
                    </dd>

                    <dt class="col-sm-4">Teléfono</dt>
                    <dd class="col-sm-8">@Model.telefono</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.email</dd>

                    <dt class="col-sm-4">Dirección</dt>
                    <dd class="col-sm-8">@Model.direccion</dd>
                </dl>
            </div>

            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancelar
                </a>

                <form asp-action="DeleteConfirmed" class="m-0">
                    <input type="hidden" asp-for="idMiembro" />
                    <button type="submit" class="btn btn-danger">
                        Suspender
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
